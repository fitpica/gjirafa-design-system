{
  "name": "@gjirafa/ds-vue",
  "version": "0.1.0",
  "description": "Vue 3 components for the Gjirafa Design System. Thin wrappers over @gjirafa/ds-core. Phase 1: GdsDatePicker.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@gjirafa/ds-core": "^0.1.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@gjirafa/ds-core": "file:../ds-core",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^24.1.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "vue": "^3.4.0"
  },
  "keywords": ["gjirafa", "design-system", "vue", "vue3", "datepicker", "calendar"],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
